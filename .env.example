# --- REQUIRED ---
# Strong random secret for signing sessions. MUST be >= 32 chars and unique.
# Generate one with:  openssl rand -hex 32
# The server refuses to start if this is empty, too short, or the old default.
JWT_SECRET=

# Initial admin account — used ONLY to seed users.json on first start.
# Set a long, unique password before first boot (the server warns on weak/empty
# values and won't seed an account if either field is blank). Change it again in
# the app after first login.
CLOUDDRIVE_USER=admin
CLOUDDRIVE_PASS=

# --- OPTIONAL ---
# Comma-separated IPs/CIDRs of trusted reverse proxies (e.g. your nginx host).
# Only requests from these peers may set X-Forwarded-For / X-Real-IP; otherwise
# the rate-limiter uses the direct connection IP (prevents header-spoofed bypass).
# TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1

# Hard cap on a single upload request body, in bytes (default 5 GiB).
# MAX_UPLOAD_BYTES=5368709120

# Comma-separated allowed CORS origins (default: none / same-origin only).
# ALLOWED_ORIGINS=https://drive.example.com
